# frontend/.env
# Place this file in your FRONTEND project root (next to package.json, vite.config.js)
# Only variables prefixed with VITE_ are exposed to the browser by Vite.
# Never put passwords or secrets here — this file's contents get bundled into
# client-side JS that anyone can view in the browser.

VITE_API_URL=https://arzoo-saree.onrender.com
# VITE_API_URL=http://localhost:8000